@model List<RWMS.Models.ViewModels.Product.ProductListViewModel>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Products</h2>
    <a asp-action="Create" class="btn btn-primary">Add Product</a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Unit</th>
            <th>Category</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.Price.ToString("C")</td>
                <td>@product.StockQuantity</td>
                <td>@product.Unit</td>
                <td>@product.Category</td>
                <td>@(product.IsActive ? "Active" : "Inactive")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    @if (product.IsActive)
                    {
                        <form asp-action="Deactivate" asp-route-id="@product.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Deactivate this product?')">Deactivate</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
