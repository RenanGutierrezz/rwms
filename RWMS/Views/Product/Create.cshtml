@model RWMS.Models.ViewModels.Product.CreateProductViewModel

@{
    ViewData["Title"] = "Add Product";
}

<h2>Add Product</h2>

<form asp-action="Create" method="post" class="mt-3" style="max-width: 600px;">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col mb-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="col mb-3">
            <label asp-for="StockQuantity" class="form-label"></label>
            <input asp-for="StockQuantity" class="form-control" />
            <span asp-validation-for="StockQuantity" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col mb-3">
            <label asp-for="Unit" class="form-label"></label>
            <input asp-for="Unit" class="form-control" placeholder="e.g. kg, box, case" />
            <span asp-validation-for="Unit" class="text-danger"></span>
        </div>
        <div class="col mb-3">
            <label asp-for="Category" class="form-label"></label>
            <input asp-for="Category" class="form-control" placeholder="e.g. Produce, Dairy" />
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save Product</button>
    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
